# Docker compose environment
# Copy this file to .env and fill in values before running docker compose up

# GitHub repo URL to pull and deploy
GITHUB_REPO_URL=https://github.com/winoiknow/www-anteon-group

# Branch to track
GITHUB_BRANCH=main

# How often (in seconds) to check for GitHub updates. Default: 900 (15 min)
CHECK_INTERVAL=900

# Port to expose the website on
PORT=80
